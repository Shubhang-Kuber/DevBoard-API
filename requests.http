@baseUrl = http://localhost:3000
@token = {{$dotenv TOKEN}}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "kuber@test.com",
  "password": "secret123"
}

### Create a task
POST {{baseUrl}}/tasks
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Learn REST APIs",
  "status": "in_progress"
}


### Get all tasks
GET {{baseUrl}}/tasks
Authorization: Bearer {{token}}